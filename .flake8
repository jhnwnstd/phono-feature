[flake8]
max-line-length = 79
extend-select = B,B950
extend-ignore = E203,W503,E501
exclude =
    .git,
    .mypy_cache,
    .pytest_cache,
    .ruff_cache,
    .venv,
    desktop/.venv,
    desktop/build,
    desktop/dist,
    web/dist,
    web/node_modules,
    web/scripts/font_cache
per-file-ignores =
    desktop/tests/conftest.py:E402
