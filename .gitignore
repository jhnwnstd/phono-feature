# Python
__pycache__/
*.py[cod]

# Distribution / packaging
# uv.lock IS tracked (workspace lockfile for the multi-package
# repo); do NOT add it here. CI verifies it stays fresh via
# `uv lock --check`.
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
env/
.python-version

# Type checking
.mypy_cache/
.ruff_cache/

# Testing
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Profiling (tools/profile_app.py output)
*.prof

# Notebooks
.ipynb_checkpoints/

# Tooling caches / scratch dirs
.uv-cache/
.codex/

# Web build (defensive: web/dist/ already covered by ``dist/``;
# these guard against future JS-dep growth)
node_modules/
.parcel-cache/

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# PyQt / Qt
*.qmlc
*.jsc

# Project: user-added inventory files are tracked; ignore scratch exports
*.bak
desktop/inventories/blevins_features.json
desktop/inventories/general_features.json

# Local research notes / scratch docs. The ``docs/`` directory is
# intentionally untracked; contributors keep personal references
# (e.g. ``docs/research.md``) here without polluting the repo.
docs/

# Build artifacts under shared/: produced by web/scripts/bake_panphon
# from the installed ``panphon`` package; regenerated on every web
# build. The ``.generated`` suffix is the project's convention for
# build-output files that ship inside source dirs.
*.generated.json

# IPA font source cache. The subset woff2 ships at
# web/assets/charis-ipa.woff2 (~64 KB, committed); the source TTF
# release (~25 MB) is too large to track. Only the README at the
# cache root stays committed so a maintainer who wants to refresh
# the subset has clear instructions.
web/scripts/font_cache/*
!web/scripts/font_cache/README.md
